{
  "name": "csddr",
  "version": "2.1.0",
  "private": true,
  "description": "Consumer DDR Song List",
  "scripts": {
    "prepare": "nuxi prepare",
    "dev": "nuxi dev",
    "build": "nuxi build",
    "preview": "nuxi preview",
    "fix": "pnpm run \"/^fix:.+/\"",
    "fix:eslint": "eslint . --fix",
    "fix:oxfmt": "oxfmt",
    "fix:oxlint": "oxlint --type-aware . --fix --fix-suggestions",
    "lint": "pnpm run \"/^lint:.+/\"",
    "lint:eslint": "eslint .",
    "lint:oxfmt": "oxfmt --check",
    "lint:oxlint": "oxlint --type-aware .",
    "lint:tsc": "nuxi typecheck"
  },
  "dependencies": {
    "@iconify-json/flag": "^1.2.10",
    "@iconify-json/lucide": "^1.2.95",
    "@iconify-json/simple-icons": "^1.2.71",
    "@nuxt/content": "^3.11.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.5.0",
    "@nuxtjs/mdc": "^0.20.2",
    "nuxt": "^4.3.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@types/node": "24.x",
    "eslint": "^9.29.3",
    "eslint-plugin-oxlint": "^1.51.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "vue-demi"
    ],
    "overrides": {
      "vite": "^8.0.0-beta.16"
    }
  }
}
